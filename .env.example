# henry_hub_swe — open-swe fork with automated review pipeline
# Copy to .env and fill in values.

# ── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── GitHub auth ──────────────────────────────────────────────────────────────
# Local dev: a PAT is enough. Get it with: gh auth token
# Needs scopes: repo (read/write contents, pull requests, issues)
GITHUB_TOKEN=

# Production: use a GitHub App instead (more secure, fine-grained permissions)
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=        # paste full PEM contents (replace newlines with \n)
# GITHUB_APP_INSTALLATION_ID=    # trailing number from the install URL after installing app
# GITHUB_WEBHOOK_SECRET=         # openssl rand -hex 32 — only needed for webhook mode

# ── LangSmith / LangGraph ────────────────────────────────────────────────────
# Required: triggers bot-token-only auth mode (uses app/PAT token for all git ops)
LANGSMITH_API_KEY_PROD=
# Optional: override LangGraph server URL (default: http://localhost:2024)
# LANGGRAPH_URL=http://localhost:2024

# ── Sandbox ──────────────────────────────────────────────────────────────────
# local = run directly on host (no isolation). Safe for dev; swap for cloud later.
# Options: local | modal | daytona | runloop | langsmith
SANDBOX_TYPE=local
# For local sandbox: absolute path to the repo the agent should work in
LOCAL_SANDBOX_ROOT_DIR=/path/to/rigs/henry_hub/repo

# ── Invocation sources (optional for local dev) ───────────────────────────────
# Only needed if you want Slack/Linear webhook triggers
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=
# SLACK_BOT_USER_ID=
# LINEAR_API_KEY=
# LINEAR_WEBHOOK_SECRET=
