{
  "review": {
    "enabled": true,
    "model": "anthropic:claude-sonnet-4-6",
    "max_retries": 3
  },
  "gates": {
    "enabled": true,
    "commands": [
      "uv venv .venv 2>/dev/null; . .venv/bin/activate && uv pip install -q '.[dev]'",
      ". .venv/bin/activate && ruff check --fix . && ruff check .",
      ". .venv/bin/activate && pytest --tb=short -q -m 'not slow and not integration'"
    ]
  }
}
